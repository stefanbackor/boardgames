{
  "name": "ironwood",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "lint-staged": "lint-staged",
    "lint-staged:lint": "eslint --fix --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint",
    "lint-staged:format": "prettier --write --ignore-unknown",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "react-router typegen && tsc",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook",
    "chromatic": "npx chromatic --project-token=$CHROMATIC_PROJECT_TOKEN"
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-portal": "^1.1.2",
    "@radix-ui/themes": "^3.1.4",
    "@react-router/node": "^7.17.0",
    "@repo/decker": "*",
    "isbot": "^5.1.0",
    "lodash": "^4.18.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router": "^7.17.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@react-router/dev": "^7.17.0",
    "@react-router/fs-routes": "^7.17.0",
    "@storybook/addon-docs": "^10.4.3",
    "@storybook/addon-links": "^10.4.3",
    "@storybook/addon-onboarding": "^10.4.3",
    "@storybook/react": "^10.4.3",
    "@storybook/react-vite": "^10.4.3",
    "@storybook/test-runner": "^0.24.4",
    "@testing-library/react": "^16.0.1",
    "@types/lodash": "^4.17.9",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "@vercel/react-router": "^1.3.1",
    "autoprefixer": "^10.4.19",
    "chromatic": "^11.12.5",
    "eslint": "^8.38.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-storybook": "^10.4.3",
    "jsdom": "^25.0.1",
    "storybook": "^10.4.3",
    "typescript": "^5.1.6",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^4.2.1",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "**/*.{js,ts,jsx,tsx}": [
      "yarn lint-staged:lint",
      "yarn lint-staged:format"
    ],
    "!**/*.{js,ts,jsx,tsx}": "yarn lint-staged:format"
  }
}
